{
  "name": "midd-gateway-api",
  "version": "1.0.0",
  "description": "Servicio OAuth 2.0-inspired que provee emisión, verificación, introspección y revocación de tokens de acceso de corta duración para aplicaciones cliente",
  "main": "./app.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node build/app.js",
    "dev": "ts-node-dev app.ts",
    "jest": "npx jest",
    "new:migration": "npx sequelize-cli migration:generate --name migration-skeleton",
    "new:seeder": "npx sequelize-cli seed:generate --name seeder-skeleton",
    "migrate": "npx sequelize-cli db:migrate",
    "seeder": "npx sequelize-cli db:seed:all",
    "migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "seeder:undo": "npx sequelize-cli db:seed:undo:all"
  },
  "keywords": [
    "express",
    "jsonapi",
    "typescript",
    "sequelize",
    "mysql",
    "swagger"
  ],
  "author": "Ivan Madera",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.24",
    "@types/supertest": "^2.0.12",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.9.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "sequelize-cli": "^6.6.2",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "7.3.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "log4js": "^6.9.1",
    "mysql2": "^3.9.2",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0"
  },
  "overrides": {
    "glob": "^13.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
